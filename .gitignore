# Xcode project — generated by XcodeGen, never committed.
# Regenerate with: xcodegen generate
*.xcodeproj/

# Xcode user state
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate

# Build products
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Local build overrides (Team ID etc.) — copy Local.xcconfig.template → Local.xcconfig
Local.xcconfig

# macOS
.DS_Store
.AppleDouble
._*
.lazyweb/
